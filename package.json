{
  "name": "integr8",
  "private": true,
  "version": "0.0.0",
  "description": "Self-hostable, event-driven e-commerce integration & sync engine.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "db:migrate": "dotenv -e .env -- pnpm --filter @integr8/db exec prisma migrate dev",
    "db:generate": "dotenv -e .env -- pnpm --filter @integr8/db exec prisma generate",
    "db:studio": "dotenv -e .env -- pnpm --filter @integr8/db exec prisma studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
