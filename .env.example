# Copy this file to .env and fill in real values. Never commit .env.
# Every variable here is validated at startup by packages/core's zod env loader.

# -- Core services (required) --
# Postgres connection string used by Prisma + apps.
DATABASE_URL=postgresql://integr8:integr8@localhost:5432/integr8?schema=public
# Redis connection string used by BullMQ (local queue driver).
REDIS_URL=redis://localhost:6379

# -- Queue driver selection --
# Which queue implementation to use: "bullmq" (local) or "sqs" (AWS).
QUEUE_DRIVER=bullmq

# -- App ports --
# API is on 3010 (not 3000) because 3000 is the Next.js default and conflicts with
# other local Next projects. Dashboard stays on 3003.
API_PORT=3010
WORKER_PORT=3001
MOCK_ERP_PORT=3002
DASHBOARD_PORT=3003

# -- Logging --
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -- Shopify (Phase 3+) --
# Webhook signing secret from Shopify Partners dev store. Used for HMAC verification.
SHOPIFY_WEBHOOK_SECRET=replace-me

# -- Anthropic (Phase 6+, server-side only) --
ANTHROPIC_API_KEY=replace-me

# -- Stripe (Phase 7+, test mode key) --
STRIPE_TEST_KEY=sk_test_replace-me

# -- AWS (Phase 8 production deploy only; leave blank locally) --
AWS_REGION=
SQS_QUEUE_URL=
